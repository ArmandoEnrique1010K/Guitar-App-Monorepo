{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": "./src",
    "paths": {
      "config/*": ["config/*"],
      "controllers/*": ["controllers/*"],
      "emails/*": ["emails/*"],
      "middlewares/*": ["middlewares/*"],
      "models/*": ["models/*"],
      "routes/*": ["routes/*"],
      "types/*": ["types/*"],
      "utils/*": ["utils/*"]
    }
  },
  "include": ["src", "src/server.ts"]
}
